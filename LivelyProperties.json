    "value": 0
  },
  "indexMultiplier": {
    "min": 0,
    "max": 50,
    "step": 1,
    "text": "Index Multiplier",
    "help": "Makes the left bigger",
    "type": "slider",
    "value": 10
  },
  "doAverageMult": {
    "type": "checkbox",
    "value": true,
    "help": "volume *= 1+avMult/(average+avMultShift)",
