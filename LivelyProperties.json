    "help": "volume+=this/(average+avAddShift)",
    "type": "slider",
    "value": 0
  },
  "averageAddShift": {
    "min": 0,
    "max": 10,
    "step": 0.01,
    "text": "Average Addition Shift",
    "help": "volume+=avAddMult/(average+this)",
